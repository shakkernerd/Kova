{
  "id": "release",
  "title": "Release Matrix",
  "objective": "Broad OpenClaw release confidence across install, upgrade, bundled plugins, model/provider, UI, failure, soak, and platform smoke scenarios.",
  "gate": {
    "id": "openclaw-release",
