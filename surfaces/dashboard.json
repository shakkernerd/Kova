{
  "id": "dashboard",
  "title": "Dashboard",
  "ownerArea": "control-ui",
  "description": "Verify dashboard command output, websocket entry, and post-dashboard gateway health.",
  "requiredStates": ["fresh"],
  "targetKinds": ["npm", "channel", "runtime", "local-build"],
  "requiredMetrics": ["dashboardConnectMs", "gatewayReadyMs", "statusMs", "websocketDisconnects"],
  "processRoles": ["gateway", "command-tree", "dashboard-cli"],
  "thresholds": { "dashboardConnectMs": 10000, "gatewayReadyMs": 30000, "statusMs": 10000 },
  "diagnostics": {
    "timelineRequiredForSourceBuild": false,
    "expectedSpans": ["dashboard.url", "gateway.websocket"]
  }
}
